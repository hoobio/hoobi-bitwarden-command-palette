root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_size = 4

# ── .NET Analyzers ──────────────────────────────────────────────

# CA1031: Do not catch general exception types
dotnet_diagnostic.CA1031.severity = suggestion

# CA1001: Types that own disposable fields should be disposable
dotnet_diagnostic.CA1001.severity = warning

# CA2000: Dispose objects before losing scope (many false positives for process-lifetime/COM objects)
dotnet_diagnostic.CA2000.severity = suggestion

# CA1822: Mark members as static
dotnet_diagnostic.CA1822.severity = warning

# CA1848: Use the LoggerMessage delegates
dotnet_diagnostic.CA1848.severity = none

# ── VS Threading Analyzers ──────────────────────────────────────

# VSTHRD002: Avoid problematic synchronous waits (.Result / .Wait())
dotnet_diagnostic.VSTHRD002.severity = warning

# VSTHRD100: Avoid async void methods
dotnet_diagnostic.VSTHRD100.severity = warning

# VSTHRD103: Call async methods when in an async method
dotnet_diagnostic.VSTHRD103.severity = warning

# VSTHRD110: Observe result of async calls
dotnet_diagnostic.VSTHRD110.severity = warning

# VSTHRD200: Use Async naming convention
dotnet_diagnostic.VSTHRD200.severity = suggestion

# ── Meziantou Analyzer ──────────────────────────────────────────

# MA0004: Use ConfigureAwait
dotnet_diagnostic.MA0004.severity = none

# MA0009: Add regex evaluation timeout
dotnet_diagnostic.MA0009.severity = warning

# MA0011: IFormatProvider is missing
dotnet_diagnostic.MA0011.severity = none

# MA0015: Specify the parameter name in ArgumentException
dotnet_diagnostic.MA0015.severity = warning

# MA0032: Use an overload with a CancellationToken argument
dotnet_diagnostic.MA0032.severity = suggestion

# MA0040: Forward the CancellationToken parameter
dotnet_diagnostic.MA0040.severity = suggestion

# MA0046: Use EventHandler<T> to declare events
dotnet_diagnostic.MA0046.severity = none

# MA0048: File name must match type name (co-located types are intentional)
dotnet_diagnostic.MA0048.severity = none

# MA0051: Method is too long
dotnet_diagnostic.MA0051.severity = suggestion

# MA0076: Do not use implicit culture-sensitive ToString
dotnet_diagnostic.MA0076.severity = none

# MA0110: Use the Regex source generator
dotnet_diagnostic.MA0110.severity = warning

# MA0006: Use string.Equals (== is fine for internal ordinal comparison)
dotnet_diagnostic.MA0006.severity = suggestion

# MA0002: Use overload with IEqualityComparer (not needed for string keys in internal code)
dotnet_diagnostic.MA0002.severity = suggestion

# MA0049: Type name should not match namespace (intentional naming)
dotnet_diagnostic.MA0049.severity = none

# MA0056: Do not call overridable members in constructor (required by SDK base classes)
dotnet_diagnostic.MA0056.severity = none

# ── StyleCop (suppress noisy rules) ────────────────────────────

# SA1101: Prefix local calls with this
dotnet_diagnostic.SA1101.severity = none

# SA1200: Using directives should be placed correctly
dotnet_diagnostic.SA1200.severity = none

# SA1309: Field names should not begin with underscore
dotnet_diagnostic.SA1309.severity = none

# SA1600: Elements should be documented
dotnet_diagnostic.SA1600.severity = none

# SA1601: Partial elements should be documented
dotnet_diagnostic.SA1601.severity = none

# SA1633: File should have header
dotnet_diagnostic.SA1633.severity = none

# SA0001: XML comment analysis disabled
dotnet_diagnostic.SA0001.severity = none

[*.{csproj,props,targets}]
indent_size = 2

# Test projects: allow underscores in method names (xUnit convention)
[*Tests/*.cs]
dotnet_diagnostic.CA1707.severity = none
# Allow new Regex() in tests (needed for passing to production code under test)
dotnet_diagnostic.MA0110.severity = none
